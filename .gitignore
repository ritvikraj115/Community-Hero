# --- Global Dependencies ---
# Ignores node_modules in the root and in any subfolder (backend/frontend)
node_modules/
.npm
.eslintcache
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Environment Variables (CRITICAL) ---
# Prevents API keys from leaking from any folder
.env
.env.*
!.env.example

# --- Build & Output Directories (React / Vite / Next.js) ---
build/
dist/
.next/
out/
build-err.log

# --- TypeScript Cache ---
*.tsbuildinfo

# --- Testing & Coverage (Frontend & Backend) ---
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & Editor Metadata ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Production Deployment Files ---
.vercel
.netlify