# Public frontend runtime config.
# React embeds these at build time, so set production values before running npm run build.
# Set REACT_APP_API_BASE directly, or set REACT_APP_BACKEND_URL and the client will append /api.
# Example production value: REACT_APP_BACKEND_URL=https://your-backend.onrender.com
REACT_APP_API_BASE=http://localhost:5000/api
REACT_APP_BACKEND_URL=http://localhost:5000
REACT_APP_GOOGLE_MAPS_API_KEY=replace_with_browser_restricted_google_maps_key
