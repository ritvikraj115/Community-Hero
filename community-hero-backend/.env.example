NODE_ENV=development
PORT=5000

# MongoDB and auth
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/community-hero
JWT_SECRET=replace_with_a_long_random_secret

# Public deployment URLs
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Optional Render/free-tier keep-alive ping.
# In production set BACKEND_URL or KEEP_ALIVE_URL to your deployed backend URL.
# On Render web services, RENDER_EXTERNAL_URL can be used automatically.
ENABLE_KEEP_ALIVE=false
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL_MS=300000

# Google AI
GEMINI_API_KEY=replace_with_google_gemini_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GOOGLE_EMBEDDING_DIMENSIONS=3072
GOOGLE_EMBEDDING_VERSION=001

# AI image validation gates.
# Low-confidence AI judgments are not auto-rejected; they continue to community voting.
ISSUE_IMAGE_MIN_SCORE=45
ISSUE_IMAGE_REJECTION_CONFIDENCE=85
RESOLUTION_IMAGE_MIN_SCORE=55
RESOLUTION_IMAGE_REJECTION_CONFIDENCE=85

# Weather
OPENWEATHER_API_KEY=replace_with_openweather_key

# Vector search and similarity tuning
ENABLE_ATLAS_VECTOR_SEARCH=false
MONGO_ISSUE_VECTOR_INDEX=issue_embedding_index
DUPLICATE_SEMANTIC_THRESHOLD=0.82
DUPLICATE_STRONG_SEMANTIC_THRESHOLD=0.92
DUPLICATE_TEXT_THRESHOLD=0.34
DUPLICATE_STRONG_TEXT_THRESHOLD=0.55
DUPLICATE_DISTANCE_METERS=100
DUPLICATE_CANDIDATE_DISTANCE_METERS=160
DUPLICATE_IMAGE_CONFIDENCE=85
DUPLICATE_SPATIAL_CANDIDATE_LIMIT=200
HISTORICAL_TEXT_CANDIDATE_LIMIT=150
HISTORICAL_TEXT_MIN_SIMILARITY=0.18
HISTORICAL_SEMANTIC_MIN_SIMILARITY=0.72

# Demo and QA scripts
API_BASE_URL=http://localhost:5000/api
DEMO_CENTER_LAT=
DEMO_CENTER_LNG=
DEMO_RADIUS_METERS=180
GPS_SEED_TIMEOUT_MS=240000
